# ==============================================================================
# SkillForge LMS — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it's in .gitignore).
# ==============================================================================

# --- Server -------------------------------------------------------------------
PORT=8083

# --- Database -----------------------------------------------------------------
# Local: mongodb://localhost:27017/skillforge
# Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/skillforge
MONGODB_URI=mongodb://localhost:27017/skillforge

# --- JWT Authentication -------------------------------------------------------
# REQUIRED: Use a strong, random secret (min 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_string_at_least_32_chars_long
JWT_EXPIRATION_MS=86400000

# ==============================================================================
# EXTERNAL SERVICE INTEGRATIONS (all optional — disabled by default)
# ==============================================================================

# --- Cloudinary (File Uploads) ------------------------------------------------
# Sign up FREE at: https://cloudinary.com
# Free tier: 25 GB storage + 25 GB bandwidth/month
#
# Steps:
#   1. Create account → go to Dashboard
#   2. Copy: Cloud Name, API Key, API Secret
#   3. Set CLOUDINARY_ENABLED=true
#
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# --- Email Service ------------------------------------------------------------
# Set EMAIL_ENABLED=true once SMTP is configured.
EMAIL_ENABLED=false
EMAIL_FROM=noreply@skillforge.dev
EMAIL_FROM_NAME=SkillForge LMS

# ---- Option A: Resend (Recommended) ------------------------------------------
# Sign up FREE at: https://resend.com (3,000 emails/month, 100/day free)
# Steps:
#   1. Create account → verify domain (or use onboarding@resend.dev for testing)
#   2. Create API key at https://resend.com/api-keys
#   3. Set EMAIL_PROVIDER=resend and uncomment spring.mail.* in application.properties
#
EMAIL_PROVIDER=none
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Option B: SendGrid ------------------------------------------------------
# Sign up FREE at: https://sendgrid.com (100 emails/day free forever)
# Steps:
#   1. Create account → verify sender identity
#   2. Create API key at Settings → API Keys (select "Mail Send")
#   3. Set EMAIL_PROVIDER=sendgrid and uncomment spring.mail.* in application.properties
#
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
